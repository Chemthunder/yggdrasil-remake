StoredData {\n    protected _content: KeyType;\n    protected _dataKey: string;\n\n    public constructor(content: KeyType, dataKey: string) {\n        super();\n        this._content = content;\n        this._dataKey = dataKey;\n    }\n\n    private get content(): KeyType {\n        return this._content;\n    }\n\n    private set content(i: KeyType) {\n        this._content = i;\n    }\n\n    private get dataKey(): string {\n        return this._dataKey;\n    }\n\n    public write() {\n        let converted = {\n            transmittedData: this.content\n        }\n\n        console.log(converted.transmittedData)\n        settings.writeJSON(this.dataKey, converted);\n        settings.\n    }\n}\n\nnamespace Yggdrasil {\n    export function isDataReal(key: string): boolean {\n        return settings.exists(key);\n    }\n\n    export function writeMiscDataToPers(data: any, key: string) {\n        settings.writeJSON(key, {\n            data: data\n        });\n    }\n\n    export function clearData() {\n        settings.clear();\n        game.reset();\n    }\n\n    export function removeSpecficData(key: string) {\n        settings.remove(key);\n    }\n}\n\ngame.consoleOverlay.setVisible(true, 1);\nif (!Yggdrasil.isDataReal(\"MyPersistentKey\")) {\n    let pers = new PersistentKey<number>(game.askForNumber(\"input nbt\"), \"MyPersistentKey\");\n    pers.write();\n} else {\n    console.log(settings.readJSON(\"MyPersistentKey\").transmittedData);\n}\n\n\n\ncontroller.A.onEvent(ControllerButtonEvent.Pressed, function () {\n    settings.clear();\n    game.reset();\n});","pxt.json":"{\n    \"name\": \"Yggdrasil\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\",\n        \"key.ts\"\n    ],\n    \"preferredEditor\": \"tsprj\",\n    \"languageRestriction\": \"javascript-only\"\n}\n"}}],"shares":[],"lastSaveTime":1776872753439}